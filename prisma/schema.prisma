datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum LeadStatus {
  NEW       @map("new")
  CONTACTED @map("contacted")
  QUALIFIED @map("qualified")
  CONVERTED @map("converted")
  LOST      @map("lost")
}

model User {
  id           String   @id @default(cuid())
  fullName     String   @map("full_name")
  email        String   @unique
  businessName String   @map("business_name")
  passwordHash String   @map("password_hash")
  resetToken   String?  @unique @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires")
  createdAt    DateTime @default(now()) @map("created_at")

  businessProfile BusinessProfile?
  products        Product[]
  faqs            FAQ[]
  leads           Lead[]
  conversations   Conversation[]
  whatsAppConfigs WhatsAppConfig[]

  @@map("users")
}

model BusinessProfile {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  description     String?
  deliveryPolicy  String?  @map("delivery_policy")
  paymentPolicy   String?  @map("payment_policy")
  returnPolicy    String?  @map("return_policy")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("business_profiles")
}

model Product {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  productName  String   @map("product_name")
  description  String
  price        Int      // Price stored in kobo/integer to avoid floating-point issues (NGN * 100)
  imageUrl     String?  @map("image_url")
  colorOptions String[] @map("color_options")
  sizeOptions  String[] @map("size_options")
  inStock      Boolean  @default(true) @map("in_stock")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("products")
}

model FAQ {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  question  String
  answer    String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("faqs")
}

model Lead {
  id              String     @id @default(cuid())
  userId          String     @map("user_id")
  customerName    String?    @map("customer_name")
  phoneNumber     String     @map("phone_number")
  productInterest String?    @map("product_interest")
  leadStatus      LeadStatus @default(NEW) @map("lead_status")
  createdAt       DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("leads")
}

model WhatsAppConfig {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  accountSid         String   @map("account_sid")
  authToken          String   @map("auth_token")
  twilioPhoneNumber  String   @map("twilio_phone_number")
  connected          Boolean  @default(true) @map("connected")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([twilioPhoneNumber])
  @@map("whatsapp_configs")
}

model Conversation {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  customerPhone       String   @map("customer_phone")
  conversationHistory Json     @map("conversation_history") // JSON array of { role: "customer"|"ai"|"vendor", content: string, timestamp: string }
  aiConfidenceScore   Float    @default(1.0) @map("ai_confidence_score")
  isEscalated         Boolean  @default(false) @map("is_escalated")
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, customerPhone])
  @@index([userId])
  @@map("conversations")
}
