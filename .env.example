# Database Connection (PostgreSQL — use Neon/Supabase for production)
DATABASE_URL="postgresql://username:password@localhost:5432/salesmate_db?schema=public"

# Auth.js Configuration (NextAuth v5)
# Generate a secret key using `openssl rand -hex 32`
NEXTAUTH_SECRET="your_nextauth_secret_key"
NEXTAUTH_URL="http://localhost:3000"

# Twilio WhatsApp credentials
# Get these from the Twilio Console (https://console.twilio.com)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_WHATSAPP_NUMBER="+14155238886"

# AI / LLM Configuration (Deepseek recommended — OpenAI-compatible)
# Get your API key from https://platform.deepseek.com
# When set to "dummy_ai_key", a rule-based mock provider is used for development (no API key needed).
AI_PROVIDER_API_KEY="your_deepseek_api_key"
AI_PROVIDER_URL="https://api.deepseek.com/v1"
AI_PROVIDER_MODEL="deepseek-chat"

# Alternative: OpenAI
# AI_PROVIDER_URL="https://api.openai.com/v1"
# AI_PROVIDER_MODEL="gpt-4o"

# Resend (Email Service — for password reset emails)
# Get your API key from https://resend.com
RESEND_API_KEY="re_..."

# Flutterwave (Nigeria payments — future use)
FLUTTERWAVE_SECRET_KEY="FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxx-X"

# Sentry Error Monitoring (https://sentry.io)
# Optional — leave blank to disable error reporting.
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"

# Logging Level (debug | info | warn | error)
# Defaults to "info" if not set.
LOG_LEVEL="info"
