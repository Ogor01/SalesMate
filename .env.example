# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/salesmate_db?schema=public"

# Auth.js Configuration (NextAuth v5)
# Generate a secret key using `openssl rand -hex 32`
NEXTAUTH_SECRET="your_nextauth_secret_key"
NEXTAUTH_URL="http://localhost:3000"

# WhatsApp Cloud API credentials
WHATSAPP_TOKEN="your_whatsapp_temporary_or_permanent_access_token"
WHATSAPP_PHONE_NUMBER_ID="your_whatsapp_phone_number_id"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your_chosen_webhook_verify_token"

# AI / LLM Configuration
# Supports OpenAI, Gemini, or Deepseek APIs
AI_PROVIDER_API_KEY="your_ai_api_key"
AI_PROVIDER_URL="https://api.openai.com/v1" # Or Deepseek API url https://api.deepseek.com/v1
AI_PROVIDER_MODEL="gpt-4o" # Or deepseek-chat

# Flutterwave subscription configuration (Nigeria payments)
FLUTTERWAVE_SECRET_KEY="FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxx-X"
